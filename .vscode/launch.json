{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server",
      "program": "${workspaceFolder}/server/index.js",
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Client (Chrome)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src"
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "Launch Client (Edge)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src"
    }
  ],
  "compounds": [
    {
      "name": "Run Full Stack (Chrome)",
      "configurations": ["Launch Server", "Launch Client (Chrome)"]
    },
    {
      "name": "Run Full Stack (Edge)",
      "configurations": ["Launch Server", "Launch Client (Edge)"]
    }
  ]
}
