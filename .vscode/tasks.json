{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Server",
      "type": "npm",
      "script": "start",
      "path": "server/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "node",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*"
        }
      }
    },
    {
      "label": "Start Client",
      "type": "npm",
      "script": "dev",
      "path": "client/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*"
        }
      }
    }
  ]
}
